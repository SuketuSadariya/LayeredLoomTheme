{% doc %}
  @prompt
    a block that can support connecting list of Dynamic dimension values 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-dimension-list-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-dimension-list__heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-dimension-list__items-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing }}px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .ai-dimension-list__item-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background_color }};
    border: {{ block.settings.item_border_width }}px solid {{ block.settings.item_border_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
  }

  .ai-dimension-list__label-{{ ai_gen_id }} {
    color: {{ block.settings.label_color }};
    font-size: {{ block.settings.label_size }}px;
    font-weight: 600;
  }

  .ai-dimension-list__value-{{ ai_gen_id }} {
    color: {{ block.settings.value_color }};
    font-size: {{ block.settings.value_size }}px;
  }

  .ai-dimension-list__empty-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    color: {{ block.settings.label_color }};
    opacity: 0.6;
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-dimension-list-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-dimension-list-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h3 class="ai-dimension-list__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h3>
  {% endif %}

  {% liquid
    assign has_dimensions = false
    if block.settings.dimension_1 != blank or block.settings.dimension_2 != blank or block.settings.dimension_3 != blank or block.settings.dimension_4 != blank or block.settings.dimension_5 != blank
      assign has_dimensions = true
    endif
  %}

  {% if has_dimensions %}
    <ul class="ai-dimension-list__items-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% assign dimension_key = 'dimension_' | append: i %}
        {% assign dimension_ref = block.settings[dimension_key] %}
        
        {% if dimension_ref != blank %}
          {% assign dimension = metaobjects[dimension_ref] %}
          {% if dimension %}
            <li class="ai-dimension-list__item-{{ ai_gen_id }}">
              <span class="ai-dimension-list__label-{{ ai_gen_id }}">
                {{ dimension.dimension_name.value }}
              </span>
              <span class="ai-dimension-list__value-{{ ai_gen_id }}">
                {{ dimension.dimension_value.value }}
              </span>
            </li>
          {% endif %}
        {% endif %}
      {% endfor %}
    </ul>
  {% else %}
    <div class="ai-dimension-list__empty-{{ ai_gen_id }}">
      Next, connect dimension metaobjects to display
    </div>
  {% endif %}
</div>

