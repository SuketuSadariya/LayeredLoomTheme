{% doc %}
  @prompt
    I want list of links which can scroll the page to that heading 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-anchor-nav-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-anchor-nav__title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.spacing }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
  }

  .ai-anchor-nav__list-{{ ai_gen_id }} {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: {{ block.settings.layout }};
    gap: {{ block.settings.spacing }}px;
    flex-wrap: wrap;
  }

  .ai-anchor-nav__item-{{ ai_gen_id }} {
    margin: 0;
  }

  .ai-anchor-nav__link-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.link_padding }}px {{ block.settings.link_padding | times: 1.5 }}px;
    color: {{ block.settings.link_color }};
    text-decoration: none;
    background-color: {{ block.settings.link_background }};
    border: {{ block.settings.link_border_width }}px solid {{ block.settings.link_border_color }};
    border-radius: {{ block.settings.link_border_radius }}px;
    font-size: {{ block.settings.link_size }}px;
    transition: all 0.3s ease;
  }

  .ai-anchor-nav__link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
    background-color: {{ block.settings.link_hover_background }};
    border-color: {{ block.settings.link_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-anchor-nav__list-{{ ai_gen_id }} {
      flex-direction: column;
    }
  }
{% endstyle %}

<anchor-navigation-{{ ai_gen_id }}
  class="ai-anchor-nav-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.title != blank %}
    <h3 class="ai-anchor-nav__title-{{ ai_gen_id }}">{{ block.settings.title }}</h3>
  {% endif %}

  <ul class="ai-anchor-nav__list-{{ ai_gen_id }}">
    {% for i in (1..10) %}
      {% liquid
        assign link_text_key = 'link_text_' | append: i
        assign link_anchor_key = 'link_anchor_' | append: i
        assign link_text = block.settings[link_text_key]
        assign link_anchor = block.settings[link_anchor_key]
      %}

      {% if link_text != blank and link_anchor != blank %}
        <li class="ai-anchor-nav__item-{{ ai_gen_id }}">
          <a
            href="#{{ link_anchor }}"
            class="ai-anchor-nav__link-{{ ai_gen_id }}"
            data-anchor-link
          >
            {{ link_text }}
          </a>
        </li>
      {% endif %}
    {% endfor %}
  </ul>
</anchor-navigation-{{ ai_gen_id }}>

<script>
  (function() {
    class AnchorNavigation{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.links = this.querySelectorAll('[data-anchor-link]');
        this.setupSmoothScroll();
      }

      setupSmoothScroll() {
        this.links.forEach((link) => {
          link.addEventListener('click', (e) => {
            e.preventDefault();
            const targetId = link.getAttribute('href').substring(1);
            const targetElement = document.getElementById(targetId);

            if (targetElement) {
              const offset = {{ block.settings.scroll_offset }};
              const elementPosition = targetElement.getBoundingClientRect().top;
              const offsetPosition = elementPosition + window.pageYOffset - offset;

              window.scrollTo({
                top: offsetPosition,
                behavior: 'smooth'
              });
            }
          });
        });
      }
    }

    customElements.define('anchor-navigation-{{ ai_gen_id }}', AnchorNavigation{{ ai_gen_id }});
  })();
</script>

