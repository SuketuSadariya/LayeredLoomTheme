{% doc %}
  @prompt
    horizontal scrollable imanges with heading and text below the image 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-scrollable-gallery-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-scrollable-gallery__container-{{ ai_gen_id }} {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: {{ block.settings.scrollbar_color }} transparent;
  }

  .ai-scrollable-gallery__container-{{ ai_gen_id }}::-webkit-scrollbar {
    height: 8px;
  }

  .ai-scrollable-gallery__container-{{ ai_gen_id }}::-webkit-scrollbar-track {
    background: transparent;
  }

  .ai-scrollable-gallery__container-{{ ai_gen_id }}::-webkit-scrollbar-thumb {
    background-color: {{ block.settings.scrollbar_color }};
    border-radius: 4px;
  }

  .ai-scrollable-gallery__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
  }

  .ai-scrollable-gallery__item-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: {{ block.settings.item_width }}px;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-scrollable-gallery__image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    background-color: #f4f4f4;
  }

  .ai-scrollable-gallery__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-scrollable-gallery__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-scrollable-gallery__image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-scrollable-gallery__content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-scrollable-gallery__heading-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    line-height: 1.3;
  }

  .ai-scrollable-gallery__text-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-scrollable-gallery__item-{{ ai_gen_id }} {
      width: {{ block.settings.item_width_mobile }}px;
    }
  }
{% endstyle %}

<horizontal-gallery-{{ ai_gen_id }}
  class="ai-scrollable-gallery-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-scrollable-gallery__container-{{ ai_gen_id }}">
    <div class="ai-scrollable-gallery__track-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign image_key = 'image_' | append: i
          assign heading_key = 'heading_' | append: i
          assign text_key = 'text_' | append: i

          assign image = block.settings[image_key]
          assign heading = block.settings[heading_key]
          assign text = block.settings[text_key]
        %}

        <div class="ai-scrollable-gallery__item-{{ ai_gen_id }}">
          <div class="ai-scrollable-gallery__image-wrapper-{{ ai_gen_id }}">
            {% if image %}
              <img
                src="{{ image | image_url: width: 800 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.item_width }}"
                height="{{ block.settings.item_width | divided_by: block.settings.image_aspect_ratio }}"
                class="ai-scrollable-gallery__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-scrollable-gallery__image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          {% if heading != blank or text != blank %}
            <div class="ai-scrollable-gallery__content-{{ ai_gen_id }}">
              {% if heading != blank %}
                <h3 class="ai-scrollable-gallery__heading-{{ ai_gen_id }}">{{ heading }}</h3>
              {% endif %}

              {% if text != blank %}
                <p class="ai-scrollable-gallery__text-{{ ai_gen_id }}">{{ text }}</p>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</horizontal-gallery-{{ ai_gen_id }}>

<script>
  (function() {
    class HorizontalGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.container = this.querySelector('.ai-scrollable-gallery__container-{{ ai_gen_id }}');
        this.setupScrollBehavior();
      }

      setupScrollBehavior() {
        if (!this.container) return;

        this.container.addEventListener('wheel', (e) => {
          if (Math.abs(e.deltaX) > Math.abs(e.deltaY)) return;
          
          e.preventDefault();
          this.container.scrollLeft += e.deltaY;
        }, { passive: false });
      }
    }

    customElements.define('horizontal-gallery-{{ ai_gen_id }}', HorizontalGallery{{ ai_gen_id }});
  })();
</script>

