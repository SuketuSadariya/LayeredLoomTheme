        "text_NeWBXt": {
          "type": "text",
          "name": "t:names.text",
          "settings": {
            "text": "<p><br/> By sourcing resins derived from renewable foundations—such as corn-starch and sugar beet—we utilize materials that are carbon-neutral in their cultivation and durable in their application. These aren't just raw materials; they are the building blocks of a circular economy. Through the precision of additive manufacturing, we transform these sustainable filaments into complex, organic geometries that remain lightweight yet structurally uncompromising, proving that the most sophisticated designs can leave the lightest footprints.<br/><br/></p>",
            "width": "fit-content",
            "max_width": "normal",
